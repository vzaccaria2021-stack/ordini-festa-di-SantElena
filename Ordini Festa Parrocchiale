<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ordini Festa Parrocchiale</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="bg-orange-50 min-h-screen">
  <div class="max-w-4xl mx-auto p-4">
    <h1 class="text-4xl font-bold text-center text-amber-900 mb-2">🎉 Festa Parrocchiale</h1>
    <p class="text-center text-xl text-amber-700 mb-8" id="data-titolo">Menu del 09-06-2026</p>

    <!-- Nome Cliente + Numero Ordine -->
    <div class="grid grid-cols-2 gap-4 mb-8">
      <input type="text" id="nome-cliente" class="p-4 rounded-2xl border-2 border-amber-300 text-lg" placeholder="Nome cliente o tavolo">
      <div class="bg-white p-4 rounded-2xl border-2 border-amber-300 text-center">
        <span class="text-sm text-gray-500">Numero Ordine</span><br>
        <span id="numero-ordine" class="text-3xl font-bold text-amber-800">#001</span>
      </div>
    </div>

    <!-- Griglia Menu -->
    <div id="menu-grid" class="grid grid-cols-2 md:grid-cols-3 gap-4"></div>
  </div>

  <!-- Pannello Totale e Conferma -->
  <div class="fixed bottom-0 left-0 right-0 bg-white border-t-4 border-amber-400 shadow-2xl p-6 max-w-4xl mx-auto">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-2xl font-bold">Totale</h3>
      <div id="totale" class="text-4xl font-bold text-green-600">0.00 €</div>
    </div>
    <button onclick="confermaOrdine()" 
            class="w-full bg-green-600 hover:bg-green-700 text-white py-6 rounded-3xl text-2xl font-bold">
      ✅ CONFERMA ORDINE
    </button>
  </div>

  <script>
    const menuData = {
      categorie: [
        { nome: "Cibo", piatti: [
          { nome: "Arancini", prezzo: 3.5 },
          { nome: "Olive Ascolane", prezzo: 4 },
          { nome: "Patatine Fritte", prezzo: 2.5 },
          { nome: "Hot Dog", prezzo: 3.5 },
          { nome: "Panino Salame", prezzo: 4 }
        ]},
        { nome: "Bevande", piatti: [
          { nome: "Acqua Naturale", prezzo: 1.5 },
          { nome: "Acqua Frizzante", prezzo: 1.5 },
          { nome: "Coca Cola", prezzo: 2.5 },
          { nome: "Aranciata", prezzo: 2.5 },
          { nome: "Birra", prezzo: 3.5 }
        ]},
        { nome: "Dolci e Gelati", piatti: [
          { nome: "Gelato Cioccolato", prezzo: 2.5 },
          { nome: "Gelato Nocciola", prezzo: 2.5 },
          { nome: "Gelato Fragola", prezzo: 2.5 },
          { nome: "Coppa Mista", prezzo: 3.5 },
          { nome: "Torta della Nonna", prezzo: 3.5 }
        ]}
      ]
    };

    let selezionati = [];

    function caricaMenu() {
      let html = '';
      menuData.categorie.forEach(cat => {
        html += `<div class="col-span-full"><h2 class="text-2xl font-bold text-amber-800 mt-8 mb-4">${cat.nome}</h2></div>`;
        
        cat.piatti.forEach(piatto => {
          html += `
            <div class="bg-white p-5 rounded-3xl shadow flex justify-between items-center">
              <div>
                <p class="font-semibold">${piatto.nome}</p>
                <p class="text-green-600 font-bold">${piatto.prezzo.toFixed(2)} €</p>
              </div>
              <input type="checkbox" onchange="toggleItem(this, '${piatto.nome}', ${piatto.prezzo})" 
                     class="w-8 h-8 accent-amber-600">
            </div>`;
        });
      });
      document.getElementById('menu-grid').innerHTML = html;
    }

    function toggleItem(checkbox, nome, prezzo) {
      if (checkbox.checked) {
        selezionati.push({nome, prezzo});
      } else {
        selezionati = selezionati.filter(item => item.nome !== nome);
      }
      aggiornaTotale();
    }

    function aggiornaTotale() {
      const totale = selezionati.reduce((sum, item) => sum + item.prezzo, 0);
      document.getElementById('totale').textContent = totale.toFixed(2) + " €";
    }

    function confermaOrdine() {
      const nome = document.getElementById('nome-cliente').value.trim() || "Cliente Anonimo";
      if (selezionati.length === 0) return alert("Seleziona almeno un prodotto!");

      let ordini = JSON.parse(localStorage.getItem('ordiniFesta') || '[]');
      const numeroOrdine = ordini.length + 1;

      const ordine = {
        numero: numeroOrdine,
        data: new Date().toLocaleString('it-IT'),
        cliente: nome,
        items: selezionati.map(i => i.nome),
        totale: selezionati.reduce((sum, i) => sum + i.prezzo, 0)
      };

      ordini.push(ordine);
      localStorage.setItem('ordiniFesta', JSON.stringify(ordini));

      alert(`✅ ORDINE #${numeroOrdine.toString().padStart(3, '0')} REGISTRATO!\n\nCliente: ${nome}\nTotale: ${ordine.totale.toFixed(2)} €\nPagamento: Contanti`);

      // Reset
      selezionati = [];
      document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
      aggiornaTotale();
      document.getElementById('nome-cliente').value = '';
    }

    caricaMenu();
  </script>
</body>
</html>
